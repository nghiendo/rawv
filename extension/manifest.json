{
  "manifest_version": 3,
  "name": "Go Downloader Integration",
  "version": "1.1",
  "description": "Blazing fast concurrent chunk downloader powered by Go.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1:8321/*"
  ]
}
